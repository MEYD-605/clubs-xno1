---
const { 
  title = "ClubsxAI", 
  description = "A Space Where Creativity Meets Precision", 
  image = "/images/bo_snake_portrait_hero.jpg",
  articleDate
} = Astro.props;

const siteUrl = "https://clubsxai.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);

// Build breadcrumb from URL path
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl }
];
let currentPath = '';
const segmentNames: Record<string, string> = {
  'about': 'About',
  'services': 'Services',
  'contact': 'Contact',
  'gallery': 'Gallery',
  'blog': 'Blog',
  'gear': "Bo's Gear",
  'bartender': 'Bartender',
  'ai-lab': 'AI Lab',
  'free-tools': 'Free Tools',
  'privacy': 'Privacy Policy',
  'terms': 'Terms of Service',
  'premium-portrait-bangkok': 'Premium Portrait Bangkok',
};
pathSegments.forEach((segment, i) => {
  currentPath += `/${segment}`;
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": i + 2,
    "name": segmentNames[segment] || title,
    "item": `${siteUrl}${currentPath}`
  });
});

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "PhotographyBusiness",
      "@id": `${siteUrl}/#localBusiness`,
      "name": "ClubsxAI",
      "url": siteUrl,
      "logo": {
        "@type": "ImageObject",
        "@id": `${siteUrl}/#logo`,
        "inLanguage": "th-TH",
        "url": `${siteUrl}/images/bo_red_neon_portrait.png`,
        "width": 512,
        "height": 512,
        "caption": "ClubsxAI Studio"
      },
      "image": {
        "@type": "ImageObject",
        "@id": `${siteUrl}/#image`,
        "url": `${siteUrl}/images/bo_snake_portrait_hero.jpg`,
        "caption": "ClubsxAI Premium Studio"
      },
      "sameAs": [
        "https://instagram.com/clubsbybo", 
        "https://facebook.com/Clubsharephoto",
        "https://tiktok.com/@clubsbybo"
      ],
      "priceRange": "฿฿",
      "telephone": "+66800416403",
      "email": "share.photothailand@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "583/5 ซ.พิบูลอุปถัมภ์ ถ.ลาดพร้าว 48 แขวงสามเสนนอก",
        "addressLocality": "เขตห้วยขวาง กรุงเทพ",
        "addressRegion": "กรุงเทพมหานคร",
        "postalCode": "10310",
        "addressCountry": "TH"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 13.7563,
        "longitude": 100.5018
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
          "opens": "09:00",
          "closes": "22:00"
        }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Photography Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Portrait Photography",
              "description": "ช่างภาพ Portrait กรุงเทพ รับถ่ายภาพบุคคล โปรไฟล์ผู้บริหาร ส่งรูปด่วน 24 ชม."
            },
            "price": "1500",
            "priceCurrency": "THB"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Wedding & Event",
              "description": "ช่างภาพงานแต่ง งานพิธี รับปริญญา นอกรอบ กรุงเทพ"
            },
            "price": "1500",
            "priceCurrency": "THB"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Food & Commercial Photography",
              "description": "ถ่ายภาพอาหาร เครื่องดื่ม สินค้า ระดับพรีเมียม"
            },
            "price": "2500",
            "priceCurrency": "THB"
          }
        ]
      },
      "description": "Club S ช่างภาพ Portrait กรุงเทพ รับถ่ายภาพบุคคล Event อาหาร สไตล์ Moody Premium ช่างภาพด่วนส่งรูปภายใน 24 ชม. ถ่ายรูปเริ่มต้น 1,500 บาท",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "5",
        "bestRating": "5",
        "worstRating": "1"
      },
      "review": [
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "คุณมิว" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "ถ่ายกับพี่โบครั้งแรกก็รักเลย! เก็บ vibe ได้ดีมาก ไม่เกร็ง รูปออกมาสวยเกินคาด"
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "คุณเจมส์" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "ถ่าย portrait สำหรับ LinkedIn พี่โบให้คำแนะนำดีมาก ได้รูปที่ professional เกินราคา"
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "คุณเบลล์ & คุณออม" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "ถ่าย pre-wedding กับพี่โบ ได้ความเป็นธรรมชาติมากๆ พี่โบเก็บ moment ได้ดีมาก"
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "คุณหมอปุ้ย" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "ถ่ายรูปทีมคลินิกและรูปโปรไฟล์หมอ ออกมาดูเป็นมืออาชีพมาก คนไข้ trust เลย"
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "คุณนิค" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "ถ่าย food photography กับ bartender shots พี่โบเข้าใจ mood ของร้านมาก"
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "ClubsxAI",
      "description": description,
      "publisher": { "@id": `${siteUrl}/#organization` },
      "inLanguage": "th-TH"
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Bo",
      "image": {
        "@type": "ImageObject",
        "@id": `${siteUrl}/#personImage`,
        "url": `${siteUrl}/images/bo_snake_portrait_hero.jpg`,
        "caption": "Bo"
      },
      "jobTitle": "Founder",
      "worksFor": { "@id": `${siteUrl}/#organization` }
    },
    {
      "@type": "FAQPage",
      "@id": `${siteUrl}/#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": "ส่งรูปไวแค่ไหน? ต้องรอกี่วัน?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "เราส่งรูปด่วนภายใน 24 ชม. (วันถัดไป) หลังจบงานครับ ไม่ต้องรอนานเป็นเดือนเหมือนที่อื่น"
          }
        },
        {
          "@type": "Question",
          "name": "มีการแต่งรูป หรือรีทัชหน้าเนียนให้ไหม?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "เราปรับแสงสี (Color Grading) ให้พรีเมียมทุกใบ และรีทัชใบหน้า (หน้าเนียน/เรียว) ให้เป็นธรรมชาติทุกใบในเซ็ตครับ"
          }
        },
        {
          "@type": "Question",
          "name": "ต้องเช็คคิวและวางมัดจำอย่างไร?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "สามารถเช็คคิวผ่าน Line หรือ Contact Form ได้เลยครับ การล็อคคิวจะนับเมื่อมีการมัดจำ ส่วนที่เหลือสามารถชำระได้หน้างานหลังจบเซสชัน"
          }
        },
        {
          "@type": "Question",
          "name": "ถ่ายนอกสถานที่ มีค่าเดินทางเพิ่มเติมไหม?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ในเขตกรุงเทพฯ (สยาม, สุขุมวิท, อารีย์) ไม่มีค่าเดินทางครับ หากเป็นปริมณฑลหรือต่างจังหวัด จะมีค่าเดินทางเพิ่มเติมตามระยะทางจริง"
          }
        },
        {
          "@type": "Question",
          "name": "เตรียมตัวอย่างไรก่อนมาถ่ายภาพ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "แนะนำให้พักผ่อนให้เพียงพอ เตรียมชุดที่มั่นใจที่สุดมาสัก 2-3 ชุด ถ้าไม่แน่ใจเรื่อง Vibe ทักมาปรึกษาก่อนได้ฟรีครับ"
          }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}/#breadcrumb`,
      "itemListElement": breadcrumbItems
    }
  ]
};

// Add Article schema if it's a blog post
if (articleDate) {
  schema["@graph"].push({
    "@type": "BlogPosting",
    "@id": `${canonicalUrl}/#article`,
    "headline": title,
    "datePublished": articleDate,
    "dateModified": articleDate,
    "author": { "@id": `${siteUrl}/#person` },
    "publisher": { "@id": `${siteUrl}/#organization` },
    "description": description,
    "mainEntityOfPage": { "@id": canonicalUrl },
    "image": {
      "@type": "ImageObject",
      "url": image.startsWith('http') ? image : `${siteUrl}${image}`
    }
  });
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
