---
import { getOGImageUrl } from '../lib/og-image';
import '../styles/globals.css';
import EnhancedSchema from '../components/EnhancedSchema.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  noindex?: boolean;
  lang?: string;
}

const {
  title = "Club S ช่างภาพด่วน กรุงเทพ | ช่างภาพ กทม ส่งรูปใน 24 ชม. - ClubsxAI",
  description = "Club S ช่างภาพด่วน กรุงเทพ รับถ่ายภาพ Portrait บุคคล งานแต่ง อาหาร ช่างภาพ กทม มืออาชีพ เริ่มต้น 1,500 บาท ส่งรูปภายใน 24 ชม. รีทัชทุกใบ จองคิวถ่ายวันนี้",
  keywords = "ช่างภาพด่วน, ช่างภาพกรุงเทพ, ช่างภาพ กทม, ช่างภาพ Portrait, รับถ่ายภาพบุคคล, ช่างภาพมืออาชีพ, ช่างภาพส่งรูปไว, ถ่ายรูปด่วน, ช่างภาพใกล้ฉัน, จ้างช่างภาพ, ช่างภาพราคาถูก, ช่างภาพรับปริญญา, ช่างภาพงานแต่ง, ช่างภาพถ่ายอาหาร, ClubsxAI",
  image = "/images/bo_snake_portrait_hero.jpg",
  noindex = false,
  lang = "th"
} = Astro.props;

// Generate dynamic OG image URL
const ogImageUrl = getOGImageUrl(title, description, image);
---
<!DOCTYPE html>
<html lang={lang} class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="keywords" content={keywords}>
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={Astro.url} />

    <!-- Geo Tags - Local SEO Bangkok -->
    <meta name="geo.region" content="TH-10" />
    <meta name="geo.placename" content="Bangkok, Thailand" />
    <meta name="geo.position" content="13.7563;100.5018" />
    <meta name="ICBM" content="13.7563, 100.5018" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:locale" content="th_TH" />
    <meta property="og:site_name" content="ClubsxAI - Club S ช่างภาพกรุงเทพ" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageUrl} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Schema.org -->
    <EnhancedSchema title={title} description={description} image={image} />

    <!-- Astro View Transitions (ClientRouter) -->
    <ClientRouter />

    <!-- Google Analytics (GA4) + Google Ads Conversion Tracking -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-67TZPJY9LF"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-67TZPJY9LF');
      gtag('config', 'AW-16603996176');
    </script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // Track phone call clicks
        document.querySelectorAll('a[href^="tel:"]').forEach(function(el) {
          el.addEventListener('click', function() {
            gtag('event', 'conversion', {'send_to': 'AW-16603996176/xc-6CLfz0ZMcEJDAs-09'});
          });
        });
        // Track LINE clicks
        document.querySelectorAll('a[href*="line.me"], a[href*="line://"]').forEach(function(el) {
          el.addEventListener('click', function() {
            gtag('event', 'conversion', {'send_to': 'AW-16603996176/ZCixCLrz0ZMcEJDAs-09'});
          });
        });
        // Track contact form submissions
        document.querySelectorAll('form').forEach(function(form) {
          form.addEventListener('submit', function() {
            gtag('event', 'conversion', {'send_to': 'AW-16603996176/nGvXCLTz0ZMcEJDAs-09'});
          });
        });
      });
    </script>
</head>
<body class="bg-black text-white font-sans antialiased selection:bg-white/10">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-orange-500 focus:text-white focus:rounded">
      Skip to main content
    </a>
    <slot />
</body>
</html>
