---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/navbar';
import Footer from '../components/footer';
import FloatingButtons from '../components/floating-buttons';
import '../styles/globals.css';
import { Image } from 'astro:assets';
import boPortrait from '../assets/images/bo_red_neon_portrait.png';
import gearImage from '../assets/images/bo_gear_mastery_kit.png';

const title = "รู้จัก Bo - Founder of ClubsxAI | ช่างภาพกรุงเทพ & Event";
const description = "ทำความรู้จักกับ Bo ช่างภาพกรุงเทพที่เชี่ยวชาญการรับถ่ายภาพ Portrait และ Event ด้วยสไตล์พรีเมียม Moody ส่งรูปด่วนภายใน 24 ชม.";
const keywords = "ประวัติช่างภาพ, Bo Clubs, ช่างภาพกรุงเทพ, ช่างภาพ Portrait, สไตล์ Moody, รับถ่ายภาพบุคคล, ช่างภาพ Event, ClubsxAI";
---

<BaseLayout title={title} description={description} keywords={keywords} image="/images/bo_red_neon_portrait.png">
    <Navbar client:load />
    
    <main class="min-h-screen pt-16 md:pt-20">
      <!-- Hero Section -->
      <section class="section-padding gradient-mesh">
        <div class="container mx-auto container-narrow text-center">
          <p class="text-sm uppercase tracking-[0.2em] text-accent mb-4" style="color: #FF6B35;">About</p>
          <h1 class="text-display-lg mb-6">ช่างภาพกรุงเทพ - The Soul Behind the Lens</h1>
          <p class="text-body-lg">Bo Clubs: ช่างภาพที่เชื่อว่าการรับถ่ายภาพคือการเล่าเรื่องราว ไม่ใช่แค่การกดชัตเตอร์</p>
        </div>
      </section>

      <!-- About Content -->
      <section class="section-padding">
        <div class="container mx-auto container-wide">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Image Side - Bo's Real Photo -->
            <div class="relative flex justify-center">
              <div class="relative">
                <!-- Profile Photo -->
                <div class="w-80 h-auto md:w-96 rounded-3xl overflow-hidden border-4 border-white/10" style="box-shadow: 0 0 60px rgba(255,107,53,0.3);">
	                  <Image
	                    src={boPortrait}
	                    alt="โบ ช่างภาพมืออาชีพกรุงเทพ ผู้ก่อตั้ง ClubsxAI สตูดิโอถ่ายภาพ Portrait สไตล์ Moody Premium"
	                    class="w-full h-auto object-cover"
	                    width={682}
	                    height={1024}
	                    loading="eager"
	                  />
	                </div>
                
                <!-- Floating Badge -->
                <div class="absolute -bottom-4 -right-4 glass-card px-6 py-4">
                  <p class="text-accent font-bold text-2xl" style="color: #FF6B35;">10+ Years</p>
                  <p class="text-body text-sm">Professional Experience</p>
                </div>

                <!-- Stats Badge Left -->
                <div class="absolute -top-4 -left-4 glass-card px-4 py-2">
                  <p class="text-white font-bold text-lg">23K+</p>
                  <p class="text-body text-xs">Followers</p>
                </div>
              </div>
            </div>

            <!-- Text Side -->
            <div class="space-y-6">
              <h2 class="text-display-md">สวัสดีครับ, ผมโบ 👋</h2>
              
              <p class="text-body-lg">
                ผมเป็นช่างภาพในกรุงเทพฯ ผู้ก่อตั้ง ClubsxAI — ถ่ายภาพที่ทำให้คุณเห็นตัวเองในมุมที่ดีที่สุด
              </p>
              
              <p class="text-body">
                ผมเริ่มถ่ายรูปจากความหลงใหลในการเล่าเรื่องราว ผ่านแสงและสี ผมไม่ได้แค่ถ่ายรูปคุณ — 
                ผมช่วยให้คุณเห็นตัวเองในมุมที่คุณอาจไม่เคยเห็นมาก่อน
              </p>
              
              <p class="text-body">
                สิ่งที่ทำให้ผมต่างจากคนอื่น? ผมใส่ใจกับ "vibe" ของแต่ละคน และสร้างบรรยากาศที่ทำให้คุณรู้สึกสบาย 
                เพราะเมื่อคุณผ่อนคลาย ความสวยงามที่แท้จริงก็จะปรากฏออกมา
              </p>

              <div class="flex flex-wrap gap-4 pt-4">
                <a href="/contact" class="btn-primary">
                  Let's Work Together
                </a>
                <a href="https://www.facebook.com/Clubsharephoto" target="_blank" rel="noopener noreferrer" class="btn-secondary">
                  📘 Follow on Facebook
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Stats Section -->
      <section class="py-16 px-6">
        <div class="container mx-auto container-wide">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <div class="glass-card p-6 text-center">
              <p class="text-3xl font-bold text-accent mb-2" style="color: #FF6B35;">1,000,000+</p>
              <p class="text-body">ชัตเตอร์ที่กดมา</p>
            </div>
            <div class="glass-card p-6 text-center">
              <p class="text-3xl font-bold text-accent mb-2" style="color: #FF6B35;">500+</p>
              <p class="text-body">Happy Clients</p>
            </div>
            <div class="glass-card p-6 text-center">
              <p class="text-3xl font-bold text-accent mb-2" style="color: #FF6B35;">23,921</p>
              <p class="text-body">Facebook Followers</p>
            </div>
            <div class="glass-card p-6 text-center">
              <p class="text-3xl font-bold text-accent mb-2" style="color: #FF6B35;">24 ชม.</p>
              <p class="text-body">ส่งรูปด่วน!</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Philosophy Section -->
      <section class="section-padding gradient-dark">
        <div class="container mx-auto container-wide">
          <div class="text-center mb-12">
            <p class="text-sm uppercase tracking-[0.2em] text-accent mb-4" style="color: #FF6B35;">Philosophy</p>
            <h2 class="text-display-md">How I Work</h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="glass-card p-8 text-center">
              <div class="text-4xl mb-4">🎯</div>
              <h3 class="text-heading mb-3">เริ่มจากคุณ</h3>
              <p class="text-body">ผมเริ่มจากสิ่งที่คุณต้องการ ฟังไอเดีย ดูสไตล์ แล้วทำให้มันเป็นจริง</p>
            </div>

            <div class="glass-card p-8 text-center">
              <div class="text-4xl mb-4">✨</div>
              <h3 class="text-heading mb-3">สร้างบรรยากาศ</h3>
              <p class="text-body">ผมสร้างบรรยากาศให้คุณสบาย ไม่เกร็ง — ตัวตนจริงๆ จะออกมาเอง</p>
            </div>

            <div class="glass-card p-8 text-center">
              <div class="text-4xl mb-4">🎨</div>
              <h3 class="text-heading mb-3">รีทัชทุกใบ</h3>
              <p class="text-body">หลังถ่ายเสร็จ ผมปรับแสงสีและรีทัชให้ทุกใบ ส่งงานภายใน 24 ชม.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Equipment Section -->
      <section class="section-padding">
        <div class="container mx-auto container-narrow">
          <div class="text-center mb-12">
            <p class="text-sm uppercase tracking-[0.2em] text-accent mb-4" style="color: #FF6B35;">Gear</p>
            <h2 class="text-display-md">My Gear</h2>
          </div>

          <div class="glass-card p-0 overflow-hidden relative group">
            <div class="absolute inset-0 bg-gradient-to-r from-black/60 to-transparent z-10"></div>
	            <Image
	              src={gearImage}
	              alt="อุปกรณ์ถ่ายภาพมืออาชีพ SONY A7III และ A7C พร้อมเลนส์ G-Master Series ของช่างภาพ ClubsxAI"
	              width={1024}
	              height={1024}
	              class="w-full h-[400px] object-cover group-hover:scale-105 transition-transform duration-[10s] ease-linear"
	              loading="lazy"
	            />
            <div class="absolute inset-0 z-20 flex items-center p-12">
              <div class="max-w-md">
                <h3 class="text-display-sm mb-4">อุปกรณ์ที่ผมใช้</h3>
                <p class="text-body mb-6">ผมใช้ SONY A7III กับ A7C คู่กับเลนส์ G-Master ให้ภาพคมชัดทุกใบ</p>
                <div class="grid grid-cols-2 gap-4">
                  <div class="bg-white/5 backdrop-blur-sm p-4 rounded-xl border border-white/10">
                    <p class="text-accent text-xs uppercase tracking-widest mb-1">Body</p>
                    <p class="text-white font-bold">SONY A7III & A7C</p>
                  </div>
                  <div class="bg-white/5 backdrop-blur-sm p-4 rounded-xl border border-white/10">
                    <p class="text-accent text-xs uppercase tracking-widest mb-1">Vision</p>
                    <p class="text-white font-bold">G-Master Series</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="section-padding gradient-dark">
        <div class="container mx-auto container-narrow text-center">
          <h2 class="text-display-md mb-6">พร้อมถ่ายรูปด้วยกันไหม?</h2>
          <p class="text-body-lg mb-10">ทักมาคุยเรื่องไอเดียได้เลยครับ ปรึกษาฟรี</p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="/contact" class="btn-primary text-lg">
              Book a Session
            </a>
            <a href="https://line.me/ti/p/~clubsbybo" target="_blank" rel="noopener noreferrer" class="btn-secondary text-lg">
              💬 Chat on Line
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer client:load />
    <FloatingButtons client:load />
</BaseLayout>
