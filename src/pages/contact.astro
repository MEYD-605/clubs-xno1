---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/navbar';
import Footer from '../components/footer';
import FloatingButtons from '../components/floating-buttons';
import '../styles/globals.css';

const title = "จองคิวช่างภาพ กรุงเทพ | รับถ่ายภาพส่งด่วน 24 ชม. เริ่ม 1,500.- ClubsxAI";
const description = "ติดต่อจองคิวช่างภาพ Portrait กรุงเทพ Club S รับถ่ายภาพบุคคล ถ่ายรูป 1,500 บาท ช่างภาพด่วนส่งรูปภายใน 24 ชม. จองผ่าน Line, Messenger หรือโทร 080-041-6403";
const keywords = "ติดต่อช่างภาพ, จองคิวถ่ายรูป, ราคาช่างภาพ, Contact Photographer, Booking Portrait, ClubsxAI Price List";
---

<BaseLayout title={title} description={description} keywords={keywords}>
    <Navbar client:load />
    
    <main class="min-h-screen pt-16 md:pt-20">
      <!-- Hero Section -->
      <section class="section-padding gradient-mesh">
        <div class="container mx-auto container-narrow text-center">
          <p class="text-sm uppercase tracking-[0.2em] text-accent mb-4" style="color: #FF6B35;">Contact</p>
          <h1 class="text-display-lg mb-6">จองคิว<span class="text-accent italic">ช่างภาพ</span>กรุงเทพ</h1>
          <p class="text-body-lg">พร้อมถ่ายรูปหรือมีคำถาม? ติดต่อช่างภาพด่วนกรุงเทพ ถ่ายรูป 1,500 บาท ส่งรูปใน 24 ชม.</p>
        </div>
      </section>

      <!-- Contact Content -->
      <section class="section-padding">
        <div class="container mx-auto container-wide">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            
            <!-- Contact Info -->
            <div class="space-y-8">
              <div>
                <h2 class="text-display-md mb-6">Get in Touch</h2>
                <p class="text-body-lg">
                  ผมยินดีตอบทุกคำถาม ไม่ว่าจะเป็นเรื่อง pricing, availability หรือแค่อยากคุยเรื่องไอเดียถ่ายภาพ
                </p>
              </div>

              <!-- Contact Methods -->
              <div class="space-y-4">
                <a href="https://m.me/Clubsharephoto" 
                   target="_blank" 
                   rel="noopener noreferrer"
                   class="glass-card p-6 flex items-center gap-4 hover:border-[#0084FF]/50 transition-all group">
                  <div class="w-12 h-12 rounded-full bg-[#0084FF] flex items-center justify-center">
                    <span class="text-2xl">💬</span>
                  </div>
                  <div>
                    <h4 class="font-medium text-white group-hover:text-[#0084FF] transition-colors">Facebook Messenger</h4>
                    <p class="text-body">Clubsharephoto (IB มาได้เลยครับ!)</p>
                  </div>
                </a>

                <a href="mailto:share.photothailand@gmail.com"
                   class="glass-card p-6 flex items-center gap-4 hover:border-accent/50 transition-all group" style="--tw-border-opacity: 0.5;">
                  <div class="w-12 h-12 rounded-full bg-zinc-700 flex items-center justify-center">
                    <span class="text-2xl">📧</span>
                  </div>
                  <div>
                    <h4 class="font-medium text-white group-hover:text-accent transition-colors" style="--tw-text-opacity: 1;">Email</h4>
                    <p class="text-body">share.photothailand@gmail.com</p>
                  </div>
                </a>

                <a href="tel:0800416403"
                   class="glass-card p-6 flex items-center gap-4 hover:border-accent/50 transition-all group">
                  <div class="w-12 h-12 rounded-full bg-zinc-700 flex items-center justify-center">
                    <span class="text-2xl">📱</span>
                  </div>
                  <div>
                    <h4 class="font-medium text-white group-hover:text-accent transition-colors">Phone</h4>
                    <p class="text-body">080-041-6403</p>
                  </div>
                </a>

                <a href="https://instagram.com/clubsbybo"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="glass-card p-6 flex items-center gap-4 hover:border-pink-500/50 transition-all group">
                  <div class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center">
                    <span class="text-2xl">📷</span>
                  </div>
                  <div>
                    <h4 class="font-medium text-white group-hover:text-pink-400 transition-colors">Instagram</h4>
                    <p class="text-body">@clubsbybo</p>
                  </div>
                </a>
              </div>

              <!-- LINE QR Code -->
              <div class="glass-card p-6 border-accent/20">
                <h4 class="font-medium text-white mb-4 flex items-center gap-2">
                  <span class="w-8 h-8 rounded-full bg-[#06C755] flex items-center justify-center text-xs">📱</span>
                  Scan to Add LINE
                </h4>
                <div class="flex flex-col md:flex-row items-center gap-6">
                  <div class="w-32 h-32 bg-white p-2 rounded-xl shrink-0 shadow-lg shadow-white/5">
	                    <img loading="lazy" src="/images/line_qr.jpg" alt="LINE QR Code" width="540" height="540" class="w-full h-full object-contain" />
	                  </div>
                  <div class="space-y-2 text-sm">
                    <p class="text-white/80 font-medium">เพิ่มเพื่อนผ่าน LINE</p>
                    <p class="text-white/40">สแกน QR Code เพื่อสอบถามรายละเอียดเพิ่มเติม หรือส่งบรีฟงานได้ทันทีครับ</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Contact Form -->
	            <div class="glass-card p-6 sm:p-10 relative overflow-hidden">
              <div id="form-success" class="hidden absolute inset-0 bg-zinc-900/95 backdrop-blur-md z-10 flex flex-col items-center justify-center text-center p-8 animate-fade-in">
                <div class="w-20 h-20 bg-accent/20 rounded-full flex items-center justify-center mb-6">
                  <span class="text-4xl text-accent">✨</span>
                </div>
                <h3 class="text-2xl font-bold text-white mb-3">ได้รับข้อมูลแล้วครับ!</h3>
                <p class="text-white/60 mb-8">ขอบคุณที่สนใจ ClubsxAI ครับ ผมจะติดต่อกลับทาง Messenger หรือโทรหาโดยเร็วที่สุดครับ</p>
                <button onclick="location.reload()" class="btn-secondary">ส่งข้อความเพิ่ม</button>
              </div>

              <h3 class="text-heading mb-6">ส่งข้อความหาผม</h3>
              <form id="contact-form" class="space-y-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-white mb-2">ชื่อ *</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder:text-white/40 focus:outline-none focus:border-accent/50 transition-colors"
                    placeholder="คุณชื่ออะไร?"
                  />
                </div>

                <div>
                  <label for="contact" class="block text-sm font-medium text-white mb-2">Line ID หรือ Email *</label>
                  <input 
                    type="text" 
                    id="contact" 
                    name="contact" 
                    required
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder:text-white/40 focus:outline-none focus:border-accent/50 transition-colors"
                    placeholder="ช่องทางที่ติดต่อกลับได้"
                  />
                </div>

                <div>
                  <label for="service" class="block text-sm font-medium text-white mb-2">สนใจ Service ไหน?</label>
                  <select 
                    id="service" 
                    name="service"
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:outline-none focus:border-accent/50 transition-colors"
                  >
                    <option value="" class="bg-zinc-900">-- เลือกบริการที่สนใจ --</option>
                    <option value="portrait" class="bg-zinc-900">Portrait & Profile (เริ่ม 1,500.-)</option>
                    <option value="graduation" class="bg-zinc-900">Graduation / นอกรอบ (เริ่ม 1,500.-)</option>
                    <option value="couple" class="bg-zinc-900">Couple & Romance (เริ่ม 1,500.-)</option>
                    <option value="event" class="bg-zinc-900">Event & Ceremony (เริ่ม 4,500.-)</option>
                    <option value="food" class="bg-zinc-900">Food & Commercial (เริ่ม 2,500.-)</option>
                    <option value="other" class="bg-zinc-900">อื่นๆ</option>
                  </select>
                </div>

                <div>
                  <label for="date" class="block text-sm font-medium text-white mb-2">วันที่ต้องการถ่าย (ถ้ามี)</label>
                  <input 
                    type="date" 
                    id="date" 
                    name="date"
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:outline-none focus:border-accent/50 transition-colors"
                  />
                </div>

                <div>
                  <label for="message" class="block text-sm font-medium text-white mb-2">ข้อความเพิ่มเติม</label>
                  <textarea 
                    id="message" 
                    name="message" 
                    rows="4"
                    class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder:text-white/40 focus:outline-none focus:border-accent/50 transition-colors resize-none"
                    placeholder="บอกเล่าเรื่องราวหรือไอเดียที่คุณอยากถ่ายได้เลย..."
                  ></textarea>
                </div>

                <button 
                  type="submit" 
                  class="btn-primary w-full text-center"
                >
                  ส่งข้อความ
                </button>
              </form>
            </div>
          </div>
        </div>
      </section>

      <!-- Map Section (Optional) -->
      <section class="section-padding gradient-dark">
        <div class="container mx-auto container-narrow text-center">
          <h3 class="text-heading mb-4">📍 Based in Bangkok</h3>
          <p class="text-body">ถ่ายได้ทุกที่ในกรุงเทพและปริมณฑล ต่างจังหวัดมีค่าเดินทางเพิ่มเติม</p>
        </div>
      </section>
    </main>

    <Footer client:load />
    <FloatingButtons client:load />

    <script is:inline>
      const form = document.getElementById('contact-form');
      const successDiv = document.getElementById('form-success');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerText;
        
        submitBtn.disabled = true;
        submitBtn.innerText = 'กำลังประมวลผล...';

        try {
          const formData = new FormData(form);
          formData.append('source', 'contact_page');

          const response = await fetch('/api/leads', {
            method: 'POST',
            body: formData
          });

          if (response.ok) {
            successDiv.classList.remove('hidden');
            form.reset();
          } else {
            const err = await response.json();
            alert('ขออภัยครับ เกิดข้อผิดพลาด: ' + (err.error || 'โปรดลองใหม่อีกครั้ง'));
          }
        } catch (error) {
          console.error(error);
          alert('ไม่สามารถเชื่อมต่อระบบได้ โปรดทัก Facebook Messenger แทนครับ');
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerText = originalText;
        }
      });
    </script>
</BaseLayout>
